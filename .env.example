# Anthropic API Key (required)
ANTHROPIC_API_KEY=sk-ant-xxxxx

# Notion Integration (optional - for pushing results to Notion)
NOTION_API_KEY=ntn_xxxxx
NOTION_DATABASE_ID=your-database-id-here
NOTION_TASKS_DB_ID=your-tasks-database-id-here
NOTION_PROJECTS_DB_ID=your-projects-database-id-here
NOTION_AREAS_DB_ID=your-areas-database-id-here
NOTION_RESOURCES_DB_ID=your-resources-database-id-here
NOTION_FRIENDS_DB_ID=your-friends-database-id-here
NOTION_COMMAND_CENTER_ID=your-command-center-page-id-here

# Google Gemini (for image generation & infographics)
GEMINI_API_KEY=your-gemini-api-key-here

# Google Maps Platform (for location search, directions, distance matrix, geocoding)
GOOGLE_MAPS_API_KEY=your-google-maps-api-key-here

# Apify (for web scraping — falls back to BeautifulSoup when quota exhausted)
APIFY_TOKEN=apify_api_xxxxx

# Agent Configuration
CLAUDE_MODEL=claude-sonnet-4-5-20250929
MAX_AGENT_TURNS=25
